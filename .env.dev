# ── Database ──────────────────────────────────────────────────────────
# Set a PostgreSQL URL to use Postgres:
#   DATABASE_URL=postgresql://user:password@localhost:5432/research_agent
#
# Leave blank or remove this line to fall back to local SQLite (zero setup).
DATABASE_URL=

# ── HuggingFace (free tier LLM) ──────────────────────────────────────
HF_TOKEN=hf_...
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Notion (optional) ────────────────────────────────────────────────
NOTION_TOKEN=ntn_...
NOTION_DATABASE_ID=...

# ── App ───────────────────────────────────────────────────────────────
DEBUG=true

# ── Scheduler ─────────────────────────────────────────────────────────
# Hour (0-23) when the daily paper job runs. Default: 7
DAILY_JOB_HOUR=7
DAILY_JOB_MINUTE=0
